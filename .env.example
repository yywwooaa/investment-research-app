# Options: snapshot, yahoo, bloomberg
VRW_DATA_SOURCE=snapshot
VRW_BLOOMBERG_HOST=localhost
VRW_BLOOMBERG_PORT=8194

# Optional deploy/local overrides.
VRW_LOCAL_DATA_DIR=data/local
VRW_SQLITE_PATH=data/local/workbench.sqlite3
VRW_SERVE_FRONTEND=true
VRW_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional public-data enrichments. Keep real keys in Render/local .env only.
ALPHAVANTAGE_API_KEY=
# Optional comma-separated failover keys. Prefer caching over extra calls; follow provider terms.
ALPHAVANTAGE_API_KEYS=
VRW_ALPHA_VANTAGE_CACHE_PATH=data/local/alpha_vantage_cache.json
VRW_COMPANY_CACHE_DIR=data/local/company_cache
VRW_COMPANY_CACHE_TTL_SECONDS=900
VRW_LAZY_UNIVERSE_LOAD=true
VRW_SEC_USER_AGENT=Variant Research Workbench your-email@example.com

# Auth gate. Set VRW_REQUIRE_INVITE=true and keep VRW_INVITE_CODE secret in Render.
VRW_REQUIRE_INVITE=false
VRW_INVITE_CODE=
VRW_ADMIN_KEY=
VRW_AUTH_SESSION_DAYS=14
VRW_PASSWORD_RESET_MINUTES=30
VRW_PUBLIC_APP_URL=http://127.0.0.1:5173

# Optional SMTP for forgot-password email.
VRW_SMTP_HOST=
VRW_SMTP_PORT=465
VRW_SMTP_USERNAME=
VRW_SMTP_PASSWORD=
VRW_SMTP_FROM=
VRW_SMTP_TLS=true
